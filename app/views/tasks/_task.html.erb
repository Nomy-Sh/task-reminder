<div id="<%= dom_id task %>">
  <p>
    <strong>Task:</strong>
    <%= task.task_id %>
  </p>

  <p>
    <strong>Title:</strong>
    <%= task.title %>
  </p>

  <p>
    <strong>Desc:</strong>
    <%= task.desc %>
  </p>

  <p>
    <strong>Time:</strong>
    <%= task.time %>
  </p>

  <p>
    <strong>Day:</strong>
    <%= task.day %>
  </p>

  <p>
    <strong>Date:</strong>
    <%= task.date %>
  </p>

  <p>
    <strong>Tags:</strong>
    <%= task.tags %>
  </p>

  <p>
    <strong>Status:</strong>
    <%= task.status %>
  </p>

  <p>
    <strong>Entity type:</strong>
    <%= task.entity_type %>
  </p>

  <p>
    <strong>Priority:</strong>
    <%= task.priority %>
  </p>

  <p>
    <strong>User:</strong>
    <%= task.user_id %>
  </p>

</div>
