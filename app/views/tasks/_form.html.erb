<%= form_with(model: task) do |form| %>
  <% if task.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(task.errors.count, "error") %> prohibited this task from being saved:</h2>

      <ul>
        <% task.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.text_field :title, placeholder: "Title", class: "form-control w-100 mt-1" %>
  </div>

  <div>
    <%= form.label "Details", style: "display: block", class: "w-100 mt-5" %>
    <%= form.text_area :desc, class: "form-control w-100 " %>
  </div>

  <div>
    <%= form.label :tags, style: "display: block", class: "w-100 mt-1"  %>
    <%= form.text_field :tags, class: "form-control w-100 "  %>
  </div>

  <div class="mt-5" style= "display: block;">
    <%= form.label :time, style: "display: inline-block" %>
    <%= form.time_field "10:00", class: "form-control w-50", style: "display: inline-block" %>
    
    <div class="form-check form-switch mt-2" style= "display: inline; float: right;">
      <input class="form-check-input" type="checkbox" checked role="switch" id="flexSwitchCheckDefault">
    </div>
  </div>

  <div class="mt-1">
    <%= form.label :day, style: "display: inline-block" %>
    <%= form.date_field :date, class: "form-control w-50", style: "display: inline-block" %>
  </div>

  <div class="mt-3">
    <%= form.label "Priority 1", style: "display: block" %>
    <%= form.range_field :priority, :min=>1, :max=>3, class: "form-range"  %>

  </div>

  <div>
    <%= form.submit class:'btn btn-primary mt-5', style:"background-color: #6562df;"  %>
  </div>
<% end %>
